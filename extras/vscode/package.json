{
  "name": "mxscript-lang",
  "displayName": "MX Script",
  "description": "Syntax highlighting, formatting, and diagnostics for MX Script (.mx files) via the bundled Language Server.",
  "version": "0.24.0",
  "publisher": "jlkdevelop",
  "author": {
    "name": "Jassim Alkharafi",
    "url": "https://github.com/jlkdevelop"
  },
  "license": "MIT",
  "homepage": "https://mxscript.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/jlkdevelop/mxscript.git"
  },
  "bugs": {
    "url": "https://github.com/jlkdevelop/mxscript/issues"
  },
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": ["Programming Languages"],
  "keywords": ["mx", "mxscript", "language", "interpreter", "web", "api"],
  "icon": "icon.png",
  "contributes": {
    "languages": [
      {
        "id": "mxscript",
        "aliases": ["MX Script", "mxscript", "mx"],
        "extensions": [".mx"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "mxscript",
        "scopeName": "source.mx",
        "path": "./syntaxes/mxscript.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "MX Script",
      "properties": {
        "mxscript.lsp.command": {
          "type": "string",
          "default": "mx",
          "description": "Path to the mx binary used as the language server."
        },
        "mxscript.lsp.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable diagnostics + format-on-save via `mx lsp`."
        }
      }
    }
  }
}
