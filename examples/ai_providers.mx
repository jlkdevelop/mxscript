// ai_providers.mx — every AI provider MX Script speaks today.
// Set the matching env var, uncomment a block, and `mx run ai_providers.mx`.
//
//   OPENAI_API_KEY      → openai (default)
//   ANTHROPIC_API_KEY   → anthropic
//   GEMINI_API_KEY      → gemini / google
//   XAI_API_KEY         → grok / xai
//   MISTRAL_API_KEY     → mistral
//   DEEPSEEK_API_KEY    → deepseek
//   GROQ_API_KEY        → groq
//   OPENROUTER_API_KEY  → openrouter
//   TOGETHER_API_KEY    → together
//   (none)              → ollama  (local llama3.2 via Ollama)
//
// Every provider answers a single shared API: ai.complete(prompt, opts).
// Switching providers is one string change. Nothing else moves.

let prompt = "In one sentence, what is MX Script?"

// --- OpenAI (default — no provider key needed in opts) ---------------
println("openai:    ", ai.complete(prompt))

